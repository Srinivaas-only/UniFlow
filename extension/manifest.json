{
  "manifest_version": 3,
  "name": "UniFlow — Spectrum Importer",
  "version": "1.0.0",
  "description": "Import your UM Spectrum courses, assignments, and deadlines into UniFlow",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://spectrum.um.edu.my/*",
    "http://localhost:8000/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://spectrum.um.edu.my/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
